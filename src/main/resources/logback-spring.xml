<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ── Local / default profile — human-readable console output ──────────── -->
    <springProfile name="local | default">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>

        <logger name="com.simplehearing" level="DEBUG" />
        <logger name="org.springframework.security" level="WARN" />
        <logger name="org.hibernate.SQL" level="DEBUG" />
        <logger name="liquibase" level="WARN" />
    </springProfile>

    <!-- ── Prod profile — structured JSON for GCP Cloud Logging ─────────────── -->
    <!--                                                                          -->
    <!-- Each log event (including full stack traces) is emitted as a single      -->
    <!-- JSON line. GCP Log Viewer parses it into structured fields:              -->
    <!--   severity, message, logger, thread, stack_trace, plus any MDC fields.  -->
    <!-- This prevents stack traces from being split across multiple log entries. -->
    <springProfile name="prod">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <!-- Map Logback levels to GCP severity field -->
                <customFields>{"service":"simple-hearing-api"}</customFields>

                <!-- GCP expects "severity" not "level" -->
                <fieldNames>
                    <levelValue>[ignore]</levelValue>
                </fieldNames>

                <!-- Include full stack trace as a single JSON string field -->
                <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                    <maxDepthPerThrowable>30</maxDepthPerThrowable>
                    <maxLength>8192</maxLength>
                    <rootCauseFirst>true</rootCauseFirst>
                </throwableConverter>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="JSON_CONSOLE" />
        </root>

        <logger name="com.simplehearing" level="INFO" />
        <logger name="org.springframework.security" level="WARN" />
        <logger name="org.hibernate" level="WARN" />
        <logger name="liquibase" level="WARN" />
        <logger name="com.zaxxer.hikari" level="WARN" />
    </springProfile>

</configuration>
