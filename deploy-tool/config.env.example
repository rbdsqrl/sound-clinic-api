# ─────────────────────────────────────────────────────────────────────────────
# GCP Deploy Tool — Configuration
# Copy this file to config.env and fill in your values.
# Run: ./run.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Your application ──────────────────────────────────────────────────────────
APP_NAME=my-app                        # lowercase, no spaces (e.g. simple-hearing)
APP_VERSION=1.0.0
DOCKER_FILE_PATH=../Dockerfile         # path to your Dockerfile

# ── Google Cloud ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=my-gcp-project-id
GCP_REGION=asia-south1                 # Mumbai. Change to your nearest region.

# ── Kubernetes ────────────────────────────────────────────────────────────────
K8S_CLUSTER_NAME=my-app-cluster
K8S_NAMESPACE=my-app
K8S_NODE_TYPE=e2-small                 # e2-micro (cheapest) / e2-small / e2-medium

# ── Database ──────────────────────────────────────────────────────────────────
DB_INSTANCE_NAME=my-app-db
DB_NAME=myapp
DB_USER=myapp
DB_PASS=change-me-to-a-strong-password
DB_TIER=db-f1-micro                    # db-f1-micro (dev) / db-g1-small (prod)

# ── App secrets ───────────────────────────────────────────────────────────────
# Add any environment variables your app needs here as KEY=value pairs.
# These are stored as Kubernetes secrets — never committed to git.
APP_ENV_VARS="
JWT_SECRET=change-me-to-a-strong-secret
SPRING_PROFILES_ACTIVE=cloud
"

# ── Domain (optional) ─────────────────────────────────────────────────────────
DOMAIN=                                # e.g. api.myapp.com — leave blank to skip ingress
